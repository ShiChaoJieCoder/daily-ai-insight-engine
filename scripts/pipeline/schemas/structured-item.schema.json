{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "topics",
    "entities",
    "event_type",
    "impact_scope",
    "polarity",
    "confidence",
    "evidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "topics": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["LLM", "Agent", "Policy", "Capital", "Product", "Research", "Other"]
      },
      "minItems": 1
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": { "type": "string", "enum": ["org", "person", "product", "gov", "other"] },
          "name": { "type": "string" }
        }
      }
    },
    "event_type": {
      "type": "string",
      "enum": ["release", "funding", "policy", "research", "opinion", "other"]
    },
    "impact_scope": {
      "type": "array",
      "items": { "type": "string", "enum": ["industry", "region", "enterprise", "consumer", "unknown"] }
    },
    "polarity": { "type": "string", "enum": ["positive", "neutral", "negative", "mixed", "unknown"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
